SMTP_HOST=smtppro.zoho.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USERNAME=mcorderoaraya@almadesign.cl
SMTP_PASSWORD=CAMBIAR_POR_APP_PASSWORD_O_PASSWORD_SMTP
SMTP_FROM=mcorderoaraya@almadesign.cl
SMTP_FROM_NAME=AlmaDesign Web
CONTACT_TO=mcorderoaraya@almadesign.cl
CONTACT_SUBJECT_PREFIX=[AlmaDesign]

# Backend RACK CORE RAG usado por /contacto/rag/*.
# En producción debe apuntar al servicio interno, no exponerse al navegador.
RAG_BASE_URL=http://127.0.0.1:8000
RAG_TIMEOUT_SECONDS=14

# Base PostgreSQL separada para el contenido editable del sitio.
# Requiere extension PHP pdo_pgsql/php-pgsql.
SITE_DATABASE_URL=pgsql:host=127.0.0.1;port=5432;dbname=almadesign_site;user=almadesign_site;password=CAMBIAR_PASSWORD

# Ruta local/produccion donde el dashboard dejara Markdown para el RAG.
RAG_DOCS_MARKDOWN_PATH=/home/mauricio/workspace/rack-core-rag-semantic/docs_markdown
